{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "ml-service/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(predict|predictions|analytics|health)",
      "dest": "ml-service/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
